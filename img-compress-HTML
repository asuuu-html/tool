  <script>
    (function() {
      // DOM refs
      const fileInput = document.getElementById('fileInput');
      const dropZone = document.getElementById('dropZone');
      const qualityRange = document.getElementById('qualityRange');
      const qualityDisplay = document.getElementById('qualityDisplay');
      const compressBtn = document.getElementById('compressBtn');
      const resetBtn = document.getElementById('resetBtn');
      const downloadBtn = document.getElementById('downloadBtn');

      const originalPreview = document.getElementById('originalPreview');
      const compressedPreview = document.getElementById('compressedPreview');
      const origSize = document.getElementById('origSize');
      const compSize = document.getElementById('compSize');
      const savings = document.getElementById('savings');
      const origFileInfo = document.getElementById('origFileInfo');
      const compFileInfo = document.getElementById('compFileInfo');

      // state
      let originalFile = null;
      let originalDataURL = null;
      let compressedDataURL = null;
      let compressedBlob = null;
      let originalFileSize = 0;

      // update quality display
      qualityRange.addEventListener('input', function() {
        qualityDisplay.textContent = this.value + '%';
      });

      // ---- file handling ----
      function loadImage(file) {
        if (!file || !file.type.startsWith('image/')) {
          alert('Please select a valid image file.');
          return;
        }
        originalFile = file;
        originalFileSize = file.size;
        const reader = new FileReader();
        reader.onload = function(e) {
          originalDataURL = e.target.result;
          originalPreview.src = originalDataURL;
          origFileInfo.textContent = `${file.name}  (${(file.size / 1024).toFixed(1)} KB)`;
          origSize.textContent = (file.size / 1024).toFixed(1) + ' KB';
          // reset compressed
          compressedPreview.src = '';
          compressedDataURL = null;
          compressedBlob = null;
          compFileInfo.textContent = 'Compress to see result';
          compSize.textContent = '—';
          savings.textContent = '—';
          downloadBtn.disabled = true;
          // auto compress?
          // optionally auto compress on load, but we let user click compress
        };
        reader.readAsDataURL(file);
      }

      // ---- compression ----
      function compressImage() {
        if (!originalDataURL) {
          alert('Please load an image first.');
          return;
        }
        const quality = parseInt(qualityRange.value, 10) / 100; // 0..1
        const img = new Image();
        img.onload = function() {
          const canvas = document.createElement('canvas');
          const ctx = canvas.getContext('2d');
          // keep aspect ratio (max 1800px width/height to avoid memory issues)
          let width = img.width;
          let height = img.height;
          const MAX = 1800;
          if (width > MAX || height > MAX) {
            const ratio = Math.min(MAX / width, MAX / height);
            width = Math.round(width * ratio);
            height = Math.round(height * ratio);
          }
          canvas.width = width;
          canvas.height = height;
          ctx.imageSmoothingEnabled = true;
          ctx.drawImage(img, 0, 0, width, height);

          // Determine output format: prefer JPEG for photos, but keep PNG if original is PNG
          let mimeType = 'image/jpeg';
          let ext = 'jpg';
          if (originalFile && originalFile.type === 'image/png') {
            mimeType = 'image/png';
            ext = 'png';
          } else if (originalFile && originalFile.type === 'image/webp') {
            // webp -> output jpeg (or png if user wants)
            mimeType = 'image/jpeg';
            ext = 'jpg';
          }
          // if quality is > 0.95, use png for better? but keep consistent
          try {
            const dataUrl = canvas.toDataURL(mimeType, quality);
            compressedDataURL = dataUrl;
            // convert to blob for size and download
            fetch(dataUrl)
              .then(res => res.blob())
              .then(blob => {
                compressedBlob = blob;
                const compSizeKB = (blob.size / 1024).toFixed(1);
                compSize.textContent = compSizeKB + ' KB';
                const origKB = (originalFileSize / 1024).toFixed(1);
                const saved = ((1 - blob.size / originalFileSize) * 100).toFixed(1);
                savings.textContent = saved + '%';
                compFileInfo.textContent = `${ext.toUpperCase()}  ·  ${compSizeKB} KB`;
                compressedPreview.src = compressedDataURL;
                downloadBtn.disabled = false;
              })
              .catch(err => {
                console.warn('Blob conversion error', err);
                // fallback: display url
                compressedPreview.src = dataUrl;
                compSize.textContent = '—';
                savings.textContent = '—';
                downloadBtn.disabled = true;
              });
          } catch (e) {
            alert('Compression error: ' + e.message);
          }
        };
        img.onerror = function() {
          alert('Failed to decode image.');
        };
        img.src = originalDataURL;
      }

      // ---- download ----
      function downloadCompressed() {
        if (!compressedBlob) {
          alert('No compressed image available. Please compress first.');
          return;
        }
        const ext = originalFile && originalFile.type === 'image/png' ? 'png' : 'jpg';
        const link = document.createElement('a');
        link.href = URL.createObjectURL(compressedBlob);
        link.download = `compressed_${Date.now()}.${ext}`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        setTimeout(() => URL.revokeObjectURL(link.href), 5000);
      }

      // ---- reset ----
      function resetAll() {
        originalFile = null;
        originalDataURL = null;
        compressedDataURL = null;
        compressedBlob = null;
        originalFileSize = 0;
        originalPreview.src = '#';
        compressedPreview.src = '#';
        origFileInfo.textContent = 'No image loaded';
        compFileInfo.textContent = 'Compress to see result';
        origSize.textContent = '—';
        compSize.textContent = '—';
        savings.textContent = '—';
        downloadBtn.disabled = true;
        fileInput.value = '';
        // reset quality to 82
        qualityRange.value = 82;
        qualityDisplay.textContent = '82%';
      }

      // ---- event binding ----
      fileInput.addEventListener('change', function(e) {
        if (this.files && this.files[0]) {
          loadImage(this.files[0]);
        }
      });

      dropZone.addEventListener('click', function() {
        fileInput.click();
      });
      dropZone.addEventListener('dragover', function(e) {
        e.preventDefault();
        this.classList.add('drag-over');
      });
      dropZone.addEventListener('dragleave', function(e) {
        e.preventDefault();
        this.classList.remove('drag-over');
      });
      dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        this.classList.remove('drag-over');
        if (e.dataTransfer.files && e.dataTransfer.files[0]) {
          loadImage(e.dataTransfer.files[0]);
          fileInput.files = e.dataTransfer.files; // sync
        }
      });

      compressBtn.addEventListener('click', compressImage);
      downloadBtn.addEventListener('click', downloadCompressed);
      resetBtn.addEventListener('click', resetAll);

      // keyboard support for dropzone
      dropZone.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          fileInput.click();
        }
      });

      // ---- AdSense injection helper (placeholder) ----
      // The AdSense code is already in the HTML, but we also 
      // allow to dynamically set the ad unit ID via a simple prompt? 
      // We keep it static but comment.
      console.log('Image Compressor ready. Replace ca-pub-xxxxxxxxxxxxxxxx with your AdSense ID.');
    })();
  </script>
